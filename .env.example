# App
APP_ENV=dev
APP_SECRET=change-me-to-a-long-random-string
APP_LOG_LEVEL=info

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=candidate_check
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Storage
STORAGE_DIR=/data/uploads

# HR session
HR_SESSION_TTL_SECONDS=86400

# Anti-captcha (для будущих коннекторов с капчей: ФССП, ГИБДД)
CAPMONSTER_KEY=
