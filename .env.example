# App
APP_ENV=dev
APP_SECRET=change-me-to-a-long-random-string
APP_LOG_LEVEL=info

# HTTP bind (на dev — 127.0.0.1; на VPS за nginx тоже 127.0.0.1; debug expose: 0.0.0.0)
APP_BIND_HOST=127.0.0.1
APP_PORT=8000
# uvicorn --reload только для dev. На проде оставить пустым.
APP_RELOAD=--reload

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=candidate_check
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Storage
STORAGE_DIR=/data/uploads

# HR session
HR_SESSION_TTL_SECONDS=86400

# Anti-captcha (для будущих коннекторов с капчей: ФССП, ГИБДД)
CAPMONSTER_KEY=
